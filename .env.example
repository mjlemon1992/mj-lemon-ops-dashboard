DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=production
PORT=3001

# Read-only QBO connector (Finance tab). Leave unset to disable the Finance data
# (the tab still renders and shows a "not configured" message).
QBO_CONNECTOR_URL=https://parkland-qbo-production.up.railway.app
QBO_API_TOKEN=
# Single-location convenience: maps every location to this connector slug unless a
# location row has its own qbo_slug. Set to the connector's slug, e.g. red-deer.
QBO_DEFAULT_SLUG=

# Marketing — call-tracking ingestion (Marketing tab). Anthropic key extracts the
# monthly Marchex/Telmetrics PDF. Unset = tab renders, ingestion disabled.
ANTHROPIC_API_KEY=
# Optional: post the monthly call card to a Slack #marketing-metrics incoming webhook.
SLACK_MARKETING_WEBHOOK_URL=
# Optional: qualified-call threshold in seconds (default 60).
QUALIFIED_MIN_SECONDS=60

