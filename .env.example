DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=production
PORT=3001

# Read-only QBO connector (Finance tab). Leave unset to disable the Finance data
# (the tab still renders and shows a "not configured" message).
QBO_CONNECTOR_URL=https://parkland-qbo-production.up.railway.app
QBO_API_TOKEN=
# Single-location convenience: maps every location to this connector slug unless a
# location row has its own qbo_slug. Set to the connector's slug, e.g. red-deer.
QBO_DEFAULT_SLUG=

# Marketing — call-tracking ingestion (Marketing tab). Anthropic key extracts the
# monthly Marchex/Telmetrics PDF. Unset = tab renders, ingestion disabled.
ANTHROPIC_API_KEY=
# Optional: post the monthly call card to a Slack #marketing-metrics incoming webhook.
SLACK_MARKETING_WEBHOOK_URL=
# Optional: qualified-call threshold in seconds (default 60).
QUALIFIED_MIN_SECONDS=60

# Chief of Staff / Atlas — morning brief sources + Slack delivery.
COS_SLACK_WEBHOOK=          # incoming webhook the morning brief is posted to
SYNC_SECRET=               # machine-to-machine key the scheduled agent uses to write briefs

# Always-on Atlas in Slack (two-way). Create a Slack app, point Event
# Subscriptions at https://<dashboard>/api/cos/slack/events, subscribe to
# message.im (DMs) + optionally message.channels, add a bot token with chat:write.
SLACK_SIGNING_SECRET=      # verifies inbound Slack requests are really from Slack
SLACK_BOT_TOKEN=           # xoxb-... bot token Atlas replies with (chat:write)
SLACK_OWNER_USER_ID=       # optional: only answer this Slack user id (e.g. U0123ABC)

