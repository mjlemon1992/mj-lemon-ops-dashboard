{
  "name": "mj-lemon-ops-dashboard",
  "version": "1.0.0",
  "description": "Multi-location automotive ops dashboard for MJ Lemon Capital Inc.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npm start\"",
    "build": "cd client && npm install && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.14.1",
    "heic-convert": "^2.1.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.2",
    "node-ical": "^0.26.1",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
